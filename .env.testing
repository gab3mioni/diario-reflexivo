APP_NAME="Diario Reflexivo (Testing)"
APP_ENV=testing
APP_KEY=base64:OHoPQm8cCC7eW+fdUcVc9j3LPkkk3J265Qn2mD7JQK8=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=error

# Conforme decisão: MySQL real em testes.
# Aponte para um schema isolado (diferente do dev!) para evitar perda de dados.
DB_CONNECTION=mysql
# Dentro do container sail, o host é "mysql" (service name do compose).
# Rodando fora do sail, use 127.0.0.1.
DB_HOST=mysql
DB_PORT=3306
# Sail cria automaticamente um banco "testing" via
# vendor/laravel/sail/database/mysql/create-testing-database.sh
DB_DATABASE=testing
DB_USERNAME=gabriel
DB_PASSWORD=password

BCRYPT_ROUNDS=4

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BROADCAST_CONNECTION=null

# O classificador e o provider de IA são bindados para fakes em testes.
# Nenhuma chamada HTTP real deve sair daqui — use Http::fake() no setup.
