flowchart TB
    subgraph CLIENT["Cliente (navegador)"]
        UI[Páginas React + Inertia<br/>ChatDiary, Dashboards, Editor de Roteiro]
    end

    subgraph HTTP["Camada HTTP"]
        R[Rotas web.php]
        MW[Middlewares<br/>Fortify · CheckRole · EnsurePasswordChanged ·<br/>HandleInertiaRequests]
    end

    subgraph CTRL["Camada de Controllers"]
        ADM[Admin*Controller]
        TCH[Teacher*Controller]
        STD[Student*Controller]
        DSH[DashboardController]
    end

    subgraph SVC["Camada de Serviços"]
        CHAT[Chat: ChatTurnProcessor<br/>NextNodeResolver · BranchClassifier]
        AIP[AiProviders<br/>OpenAi · Gemini · ...]
        ALR[ResponseAlertService]
        DIA[DiaryAnalysisService]
    end

    subgraph DATA["Persistência"]
        M[Models Eloquent]
        DB[(Banco de dados)]
    end

    subgraph ASYNC["Processamento assíncrono"]
        Q[(Fila do Laravel)]
        JOB[Job<br/>AnalyzeDiaryResponse]
        LLM[Provedor LLM<br/>externo]
    end

    UI <--> R
    R --> MW --> CTRL
    CTRL --> SVC
    SVC --> M --> DB
    DIA --> Q --> JOB --> LLM
    CHAT --> AIP --> LLM

